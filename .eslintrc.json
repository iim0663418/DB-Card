{
  "env": {
    "browser": true,
    "es2021": true,
    "worker": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "Request": "readonly",
    "Response": "readonly",
    "Headers": "readonly",
    "URL": "readonly",
    "URLSearchParams": "readonly",
    "Image": "readonly",
    "FileReader": "readonly",
    "AbortController": "readonly",
    "QRCode": "readonly",
    "API_BASE": "readonly",
    "showToast": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|^e$|^error$" }],
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-useless-catch": "off"
  }
}
